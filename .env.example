# ================================================================
# FALTA 1 — Variables de entorno
# Copiá este archivo como ".env" y completá los valores
# NUNCA subas el archivo .env a Git
# ================================================================

# ── FIREBASE ────────────────────────────────────────────────────
# Obtenés estos valores en Firebase Console > Configuración del proyecto
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ── MERCADOPAGO (solo para Cloud Functions, no el frontend) ─────
# El Access Token solo va en las Cloud Functions, nunca en el frontend
# Se configura con: firebase functions:secrets:set MP_ACCESS_TOKEN
# O en el panel de Firebase > Functions > Secrets
# MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# La Public Key sí puede ir en el frontend (solo lectura)
# VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
